# CTI-Checkup UI – Frontend environment
# Copy to .env and customize. Only VITE_* are exposed to the React app.

# Backend API URL (used by the React app to call the API server)
VITE_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# All other secrets (API keys for CLI/UI) go in ~/.cti-checkup/.env
# See project root .env.example for the full list (AbuseIPDB, IPInfo, OpenAI, etc.).
# The API server loads ~/.cti-checkup/.env at startup so the CLI gets those keys.
# -----------------------------------------------------------------------------
