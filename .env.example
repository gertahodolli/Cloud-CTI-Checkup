# =============================================================================
# CTI-Checkup – Environment template
# =============================================================================
# Copy to the project root as .env and fill in your values:
#   cp .env.example .env
#
# The UI saves API keys to this project .env. The app also reads from
# ~/.cti-checkup/.env (fallback) and from the process environment.
# Do not commit .env (it is in .gitignore).
#
# For the React frontend only: copy VITE_* to frontend/.env if you change them.
# =============================================================================

# -----------------------------------------------------------------------------
# Frontend (Vite) – only when building/running the React app
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# API server (Node) – optional
# -----------------------------------------------------------------------------
# PORT=3001

# -----------------------------------------------------------------------------
# Threat intelligence – for CLI and UI (intel ip, domain, hash)
# -----------------------------------------------------------------------------
# AbuseIPDB – REQUIRED for "intel ip" (IP reputation)
# https://www.abuseipdb.com/
CTICHECKUP_ABUSEIPDB_API_KEY=

# IPInfo – REQUIRED for "intel domain" (domain lookup and cloud attribution)
# https://ipinfo.io/
CTICHECKUP_IPINFO_TOKEN=

# Set only if your IPinfo token has "Limit Referring Domains" enabled
# CTICHECKUP_IPINFO_REFERRER=https://yourdomain.com

# VirusTotal – optional for "intel hash" (file/URL/hash lookups)
# https://www.virustotal.com/
CTICHECKUP_VIRUSTOTAL_API_KEY=

# -----------------------------------------------------------------------------
# AI – for CloudTrail summarization (optional; baseline mode works without)
# -----------------------------------------------------------------------------
# OpenAI API key
CTICHECKUP_AI_OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Optional: config and AWS
# -----------------------------------------------------------------------------
# CTICHECKUP_CONFIG=/path/to/config.yaml
# AWS_PROFILE=default
# AWS_REGIONS=us-east-1,eu-west-1
# AWS_CONFIG_FILE=/path/to/config
# AWS_SHARED_CREDENTIALS_FILE=/path/to/credentials
